---
import Logo from '@components/ui/Logo.astro'
import Github from '@components/icons/github.astro'
import ToggleTheme from '@components/ui/ToggleTheme.astro'
import Menu from '@components/icons/menu.astro'
import Enlace from '@components/ui/Enlace.astro'

const isHome =
  Astro.url.pathname === '/' || Astro.url.pathname === '/index.html'

const section = (id: string) => (isHome ? `#${id}` : `/#${id}`)

const navItems = [
  {
    href: section('animation-collection'),
    label: 'Collection',
    full: 'Animation Collection',
    hash: true
  },
  {
    href: section('scroll-animations'),
    label: 'Scroll',
    full: 'Scroll Animations',
    hash: true
  },
  {
    href: section('dialog-effects'),
    label: 'Dialogs',
    full: 'Dialog Effects',
    hash: true
  },
  {
    href: section('faq'),
    label: 'FAQ',
    full: 'FAQ',
    hash: true
  }
]

const navLinkClass =
  'inline-flex items-center px-2 py-1 text-[13px] font-medium tracking-tight text-slate-500 transition-colors hover:text-slate-900 focus-visible:ring-2 focus-visible:ring-blue-500 focus-visible:outline-none dark:text-slate-400 dark:hover:text-white xl:px-2.5'
const mobileNavLinkClass =
  'block rounded-lg px-3 py-2.5 text-base font-medium text-slate-700 transition-colors hover:text-slate-900 focus-visible:ring-2 focus-visible:ring-blue-500 focus-visible:outline-none dark:text-slate-200 dark:hover:text-white'
---

<style>
  .header-scroll {
    --header-opacity: 0;
    background: rgb(255 255 255 / calc(var(--header-opacity) * 0.82));
    border-color: rgb(226 232 240 / var(--header-opacity));
    backdrop-filter: blur(calc(var(--header-opacity) * 10px));
    -webkit-backdrop-filter: blur(calc(var(--header-opacity) * 10px));
  }

  :global(.dark) .header-scroll {
    background: rgb(5 5 5 / calc(var(--header-opacity) * 0.78));
    border-color: rgb(51 65 85 / calc(var(--header-opacity) * 0.85));
  }

  .logo-scroll {
    --logo-opacity: 0;
    opacity: var(--logo-opacity);
    transform: translateY(calc((1 - var(--logo-opacity)) * 10px));
  }

  .logo-scroll[aria-hidden='true'] {
    pointer-events: none;
  }

  .logo-scroll[data-always-visible='true'] {
    --logo-opacity: 1;
    opacity: 1;
    transform: none;
  }
</style>

<script>
  const btn = document.getElementById('menu-btn')
  const menu = document.getElementById('menu')
  const isHome =
    window.location.pathname === '/' ||
    window.location.pathname === '/index.html'

  const setMenuOpen = (open: boolean) => {
    if (!btn || !menu) return

    menu.classList.toggle('hidden', !open)
    btn.setAttribute('aria-expanded', String(open))
    btn.setAttribute('aria-label', open ? 'Close menu' : 'Open menu')
    document.body.classList.toggle(
      'overflow-hidden',
      open && window.matchMedia('(max-width: 1023px)').matches
    )

    if (open) {
      const firstLink = menu.querySelector<HTMLElement>(
        'a[href], button:not([disabled])'
      )
      firstLink?.focus()
    }
  }

  if (btn && menu) {
    btn.addEventListener('click', () => {
      const isHidden = menu.classList.contains('hidden')
      setMenuOpen(isHidden)
    })

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !menu.classList.contains('hidden')) {
        if (window.matchMedia('(max-width: 1023px)').matches) {
          setMenuOpen(false)
          btn.focus()
        }
      }
    })

    menu.querySelectorAll('a[data-enlace], a[href]').forEach((link) => {
      link.addEventListener('click', () => {
        if (window.matchMedia('(max-width: 1023px)').matches) {
          setMenuOpen(false)
        }
      })
    })
  }

  const logoContainer = document.getElementById('logo-container')
  const header = document.getElementById('header')
  const alwaysVisible = logoContainer?.dataset.alwaysVisible === 'true'

  const handleScroll = () => {
    const scrollY = window.scrollY
    const progress = alwaysVisible ? 1 : Math.min(scrollY / 100, 1)
    const isLogoInteractive = alwaysVisible || progress > 0.05

    header?.style.setProperty('--header-opacity', String(Math.min(scrollY / 100, 1) || (alwaysVisible ? 0.85 : 0)))
    // On non-home pages keep a light header background always
    if (alwaysVisible) {
      header?.style.setProperty(
        '--header-opacity',
        String(Math.max(0.75, Math.min(scrollY / 100, 1)))
      )
    }
    logoContainer?.style.setProperty('--logo-opacity', String(progress))

    if (logoContainer) {
      if (isLogoInteractive) {
        logoContainer.removeAttribute('aria-hidden')
        logoContainer.removeAttribute('tabindex')
      } else {
        logoContainer.setAttribute('aria-hidden', 'true')
        logoContainer.setAttribute('tabindex', '-1')
      }
    }
  }

  window.addEventListener('scroll', handleScroll, { passive: true })
  handleScroll()

  document.querySelectorAll('a.skip-link').forEach((link) => {
    link.addEventListener('click', (event) => {
      const href = link.getAttribute('href')
      if (!href?.startsWith('#')) return
      const target = document.querySelector<HTMLElement>(href)
      if (!target) return
      event.preventDefault()
      if (!target.hasAttribute('tabindex')) target.setAttribute('tabindex', '-1')
      target.focus({ preventScroll: true })
      target.scrollIntoView({ behavior: 'smooth', block: 'start' })
      history.pushState(null, '', href)
    })
  })

  void isHome
</script>

<a href='#main-content' class='sr-only skip-link'>Skip to main content</a>

<header
  id='header'
  class='fixed inset-x-0 top-0 z-20 border-b border-transparent header-scroll'
>
  <div
    class='mx-auto flex h-14 max-w-6xl items-center gap-3 px-4 sm:h-16 sm:gap-4 sm:px-6 lg:px-8'
  >
    <a
      id='logo-container'
      href={isHome ? '#top' : '/'}
      aria-label={isHome ? 'Back to top' : 'Tailwind Animations home'}
      aria-hidden={isHome ? 'true' : undefined}
      tabindex={isHome ? '-1' : undefined}
      data-always-visible={isHome ? undefined : 'true'}
      class='logo-scroll flex min-w-0 shrink-0 items-center gap-2 rounded-xl no-underline outline-none focus-visible:ring-2 focus-visible:ring-blue-500 focus-visible:ring-offset-2 focus-visible:ring-offset-white dark:focus-visible:ring-offset-slate-950'
    >
      <Logo
        class='aspect-square size-8 shrink-0 sm:size-9'
        iconClass='size-4 sm:size-5 animate-float-subtle'
      />
      <span
        class='truncate text-base font-bold tracking-tight text-slate-900 sm:text-lg dark:text-white'
        aria-hidden='true'
      >
        Tailwind <span class='text-blue-500'>Animations</span>
      </span>
    </a>

    <nav
      class='ml-auto hidden min-w-0 items-center gap-0.5 lg:flex xl:gap-1'
      aria-label='Primary'
    >
      {
        navItems.map((item) =>
          item.hash && isHome ? (
            <Enlace
              href={item.href}
              class={navLinkClass}
              title={item.full !== item.label ? item.full : undefined}
            >
              <span class='xl:hidden'>{item.label}</span>
              <span class='hidden xl:inline'>{item.full}</span>
            </Enlace>
          ) : (
            <a
              href={item.href}
              class={navLinkClass}
              title={item.full !== item.label ? item.full : undefined}
            >
              <span class='xl:hidden'>{item.label}</span>
              <span class='hidden xl:inline'>{item.full}</span>
            </a>
          )
        )
      }
    </nav>

    <div class='flex shrink-0 items-center gap-0.5 sm:gap-1 lg:ml-2'>
      <ToggleTheme />

      <a
        aria-label='View repository on GitHub (opens in a new tab)'
        href='https://github.com/midudev/tailwind-animations'
        target='_blank'
        rel='noopener noreferrer'
        class='inline-flex size-10 min-h-10 min-w-10 items-center justify-center rounded-full text-slate-500 transition-colors hover:bg-slate-100 hover:text-slate-800 focus-visible:ring-2 focus-visible:ring-blue-500 focus-visible:outline-none sm:size-11 sm:min-h-11 sm:min-w-11 dark:text-slate-400 dark:hover:bg-white/5 dark:hover:text-slate-200'
      >
        <Github class='size-5' aria-hidden='true' />
      </a>

      <button
        id='menu-btn'
        type='button'
        aria-label='Open menu'
        aria-expanded='false'
        aria-controls='menu'
        class='inline-flex size-10 min-h-10 min-w-10 items-center justify-center rounded-full text-slate-700 transition-colors hover:bg-slate-100 focus-visible:ring-2 focus-visible:ring-blue-500 focus-visible:outline-none lg:hidden sm:size-11 sm:min-h-11 sm:min-w-11 dark:text-slate-200 dark:hover:bg-white/5'
      >
        <Menu class='size-6' aria-hidden='true' />
        <span class='sr-only'>Menu</span>
      </button>
    </div>
  </div>

  <div
    id='menu'
    class='hidden border-t border-slate-200/80 bg-white/95 backdrop-blur-xl lg:hidden dark:border-white/10 dark:bg-[#050505]/95'
  >
    <nav
      class='mx-auto flex max-w-6xl flex-col gap-1 px-4 py-4 sm:px-6'
      aria-label='Mobile'
    >
      {
        navItems.map((item) =>
          item.hash && isHome ? (
            <Enlace href={item.href} class={mobileNavLinkClass}>
              {item.full}
            </Enlace>
          ) : (
            <a href={item.href} class={mobileNavLinkClass}>
              {item.full}
            </a>
          )
        )
      }
    </nav>
  </div>
</header>
