                        class='rounded-xl bg-slate-950 px-4 py-2 text-sm font-bold text-white transition hover:bg-emerald-600 focus-visible:ring-2 focus-visible:ring-emerald-500 focus-visible:ring-offset-2 focus-visible:outline-none dark:bg-white dark:text-slate-950 dark:hover:bg-emerald-300 dark:focus-visible:ring-offset-slate-950'
