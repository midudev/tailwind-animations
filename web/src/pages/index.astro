                    aria-labelledby={`${example.id}-title`}
                    aria-describedby={`${example.id}-description`}
                  >
                    <div class='border-b border-slate-200 px-5 py-4 dark:border-slate-800'>
                      <span class='text-xs font-bold tracking-widest text-emerald-600 uppercase dark:text-emerald-300'>
                        {example.eyebrow}
                      </span>
                      <h4
                        id={`${example.id}-title`}
                        class='mt-2 text-xl font-bold'
                      >
                        {example.dialogTitle}
                      </h4>
                    </div>

                    <div class='px-5 py-5'>
                      <p
                        id={`${example.id}-description`}
                        class='leading-7 text-slate-600 dark:text-slate-300'
                      >
                        {example.dialogDescription}
                      </p>
                      <code class='mt-5 block rounded-xl border border-slate-200 bg-slate-50 p-3 font-mono text-xs leading-5 break-all text-slate-600 dark:border-slate-800 dark:bg-slate-900 dark:text-slate-300'>
