                    command='show-modal'
                    class='mt-6 inline-flex items-center justify-center rounded-xl border border-slate-200 px-4 py-2.5 text-sm font-bold text-slate-900 transition hover:-translate-y-0.5 hover:border-emerald-400 hover:text-emerald-600 focus-visible:ring-2 focus-visible:ring-emerald-500 focus-visible:ring-offset-2 focus-visible:outline-none active:translate-y-0 dark:border-slate-800 dark:text-white dark:hover:border-emerald-300 dark:hover:text-emerald-300 dark:focus-visible:ring-offset-slate-950'
                  >
