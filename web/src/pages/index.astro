          <div class='grid gap-4 sm:grid-cols-2 xl:grid-cols-4'>
            {
              dialogModifierExamples.map((example) => (
                <div class='dialog-example-card flex min-h-64 flex-col justify-between rounded-2xl border border-slate-200 bg-white p-5 shadow-lg shadow-slate-200/40 dark:border-slate-800 dark:bg-slate-950 dark:shadow-none'>
                  <div>
                    <div class='flex items-center justify-between gap-3'>
                      <span class='text-[10px] font-bold tracking-widest text-emerald-600 uppercase dark:text-emerald-300'>
                        {example.eyebrow}
