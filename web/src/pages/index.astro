const dialogClassTransformer = {
  name: 'dialog-class-highlight',
  span(hast: any, _line: number, _col: number, _lineElement: any, token: any) {
    const className = 'animate-dialog'
    const content = token.content

    if (typeof content !== 'string' || !content.includes(className)) return

    const parts = content.split(className)
    const children: any[] = []

    parts.forEach((part, index) => {
      if (part) children.push({ type: 'text', value: part })
      if (index < parts.length - 1) {
        children.push({
          type: 'element',
          tagName: 'span',
          properties: { class: 'dialog-class-highlight' },
          children: [{ type: 'text', value: className }]
        })
      }
    })

    hast.children = children
  }
}

